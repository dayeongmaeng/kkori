{
  "expo": {
    "name": "꼬리",
    "slug": "kkori",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "kkori",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "오늘의 사진을 찍기 위해 카메라가 필요해요.",
        "NSPhotoLibraryAddUsageDescription": "사진첩에 사진을 저장하기 위해 접근 권한이 필요해요.",
        "NSPhotoLibraryUsageDescription": "사진을 저장하고 불러오기 위해 사진첩 접근 권한이 필요해요."
      },
      "bundleIdentifier": "com.kkutudio.kkori"
    },
    "android": {
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#FAF8F5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kkutudio.kkori"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF8F5",
          "dark": {
            "backgroundColor": "#FAF8F5"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-web-browser",
      "expo-notifications",
      [
        "@sentry/react-native/expo",
        {
          "organization": "kkutudio",
          "project": "kkori-client"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f538a338-0ce0-436e-88d4-66962ac19020"
      }
    },
    "owner": "dayeongmaeng"
  }
}
